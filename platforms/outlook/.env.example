# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your Outlook integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# Your Outlook / Microsoft 365 email address
OUTLOOK_EMAIL=you@outlook.com

# Your password or app password
# Microsoft 365: generate an app password at account.microsoft.com → Security → Advanced security options
OUTLOOK_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.

# Base URL — override to use a local AnuraGate instance
GATE_URL=https://anuragate.com
