# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your LinkedIn integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# LinkedIn OAuth access token
# Create an app at linkedin.com/developers → Auth → OAuth 2.0 tokens
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful professional assistant.

# Base URL — override to use a local AnuraGate instance
GATE_URL=https://anuragate.com
