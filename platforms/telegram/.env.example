# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your Telegram integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# Telegram API credentials — get from https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.
