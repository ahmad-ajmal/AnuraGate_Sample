# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your WhatsApp Business integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# WhatsApp Business Cloud API credentials
# Meta App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# App secret — Meta App → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your-app-secret

# Verify token — any string you choose
# Set the same value in: Meta App → WhatsApp → Configuration → Verify Token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.
