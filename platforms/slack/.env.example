# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your Slack integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# Slack tokens — from https://api.slack.com/apps → your app
# Bot User OAuth Token (OAuth & Permissions page)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
# App-Level Token (Basic Information → App-Level Tokens, scope: connections:write)
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.

# Base URL — override to use a local AnuraGate instance
GATE_URL=https://anuragate.com
