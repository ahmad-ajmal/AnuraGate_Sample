# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your Gmail integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# Your Gmail address
GMAIL_EMAIL=you@gmail.com

# App password (NOT your regular password)
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.

# Base URL — override to use a local AnuraGate instance
GATE_URL=https://anuragate.com
