# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your Telegram Bot integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Webhook secret — set in the AnuraGate dashboard when creating the integration
# This is used by AnuraGate to verify events are from Telegram
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful assistant.

# Base URL — override to use a local AnuraGate instance
GATE_URL=https://anuragate.com
