# Get these from your AnuraGate dashboard → Settings → API Keys
GATE_KEY=gk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Integration ID — dashboard → Integrations → your GitHub integration → copy ID
INTEGRATION_ID=ti_xxxx_xxxxxx

# GitHub personal access token with repo:write scope
# Create at github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — any string you choose
# Set the same value in: GitHub repo → Settings → Webhooks → your webhook → Secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# The trigger phrase users must include in comments to invoke the AI (default: @ai)
BOT_TRIGGER=@ai

# Optional
# Model — any model on your AnuraGate key (e.g. gpt-4o, gemini-2.0-flash)
MODEL=
SYSTEM_PROMPT=You are a helpful code review assistant. Keep your responses concise and technical. When reviewing code, focus on correctness, clarity, and potential bugs.
